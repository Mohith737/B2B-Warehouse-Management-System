# /home/mohith/Catchup-Mohith/.env.example
# ── Database ──────────────────────────────────────────────
DATABASE_URL=REDACTED_SEE_ENV
POSTGRES_USER=stockbridge
POSTGRES_PASSWORD=REDACTED_SEE_ENV
POSTGRES_DB=stockbridge

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_CACHE_DB=0
REDIS_AUTH_DB=1

# ── JWT ───────────────────────────────────────────────────
SECRET_KEY=your-secret-key-minimum-32-characters-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Auth Rate Limiting ────────────────────────────────────
AUTH_RATE_LIMIT_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=900

# ── Temporal ─────────────────────────────────────────────
TEMPORAL_HOST=temporal-server
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default
TEMPORAL_DB=temporal

# ── Admin Seed ───────────────────────────────────────────
INITIAL_ADMIN_EMAIL=admin@stockbridge.local
INITIAL_ADMIN_PASSWORD=REDACTED_SEE_ENV

# ── SendGrid ─────────────────────────────────────────────
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@stockbridge.local
SENDGRID_SANDBOX_MODE=true

# ── Application ──────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── pgAdmin (dev-tools profile only) ─────────────────────
PGADMIN_DEFAULT_EMAIL=admin@stockbridge.local
PGADMIN_DEFAULT_PASSWORD=REDACTED_SEE_ENV
